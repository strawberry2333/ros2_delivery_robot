# =============================================================================
# SubmitOrder.srv — 提交配送订单服务
# =============================================================================
# 用途：外部系统或用户向配送系统提交新的配送订单。
# 使用场景：
#   - 命令行通过 ros2 service call /submit_order 提交订单
#   - 上层调度系统（如 Web 后台）通过 ROS2 服务客户端提交订单
# 服务端行为：
#   - 校验订单合法性（order_id 非空且唯一、站点存在且不同）
#   - 校验通过后将订单加入优先级队列，返回 accepted=true
#   - 校验失败则返回 accepted=false，并在 reason 中说明拒绝原因
# 服务名称：/submit_order
# =============================================================================

# ---- 请求 (Request) ----

# 待提交的配送订单
# 包含 order_id、pickup_station、dropoff_station、priority 等完整信息
# 详见 DeliveryOrder.msg 的字段说明
delivery_interfaces/DeliveryOrder order

---

# ---- 响应 (Response) ----

# 订单是否被接受
# true — 订单校验通过，已加入配送队列
# false — 订单被拒绝，具体原因见 reason 字段
bool accepted

# 结果说明
# accepted=true 时：返回确认信息，如 "Order accepted"
# accepted=false 时：返回拒绝原因，如 "Duplicate order_id", "Unknown station: station_X"
string reason
