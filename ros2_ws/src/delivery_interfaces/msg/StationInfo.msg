# =============================================================================
# StationInfo.msg — 站点信息消息
# =============================================================================
# 用途：描述仓库/室内环境中的一个配送站点的位置和类型信息。
# 这条消息是站点配置的结构化表达，供 manager/executor 在运行时查找和校验。
# 使用场景：
#   - stations.yaml 配置文件解析后，每个站点对应一条此消息
#   - delivery_manager 根据 station_id 查找对应的坐标，发送导航目标
#   - 可通过话题或服务向外部系统暴露所有可用站点列表
# 坐标系：所有坐标均基于 Nav2 使用的 map 坐标系（map frame）。
# =============================================================================

# 站点唯一标识符。
# 必须与 DeliveryOrder.msg 中的 pickup_station / dropoff_station 匹配。
# 命名建议：语义化命名，如 "kitchen"、"room_101"、"station_A"。
# 约束：非空字符串，在同一配置文件中不可重复。
string station_id

# ---------------------------------------------------------------------------
# 站点在地图坐标系（map frame）中的位姿。
# 这些坐标用于生成 Nav2 导航目标（geometry_msgs/PoseStamped）。
# 通常从 RViz 中使用 "Publish Point" 工具获取，或在地图上手动标注。
# ---------------------------------------------------------------------------

# X 轴坐标（米），地图坐标系下的水平位置。
float64 x

# Y 轴坐标（米），地图坐标系下的垂直位置。
float64 y

# 偏航角（弧度），机器人到达站点后的朝向。
# 取值范围：-pi ~ pi（-3.14159 ~ 3.14159）。
# 0 表示正前方（X 轴正方向），pi/2 表示左转 90 度（Y 轴正方向）。
# 该角度决定机器人停靠站点时的面朝方向，影响装卸货操作的便利性。
float64 yaw

# ---------------------------------------------------------------------------
# 站点类型枚举常量。
# 用于区分站点功能，delivery_manager 据此进行调度决策。
# ---------------------------------------------------------------------------
uint8 TYPE_PICKUP=0                  # 取货站点：机器人在此站点装载货物
uint8 TYPE_DROPOFF=1                 # 送货站点：机器人在此站点卸载货物
uint8 TYPE_CHARGE=2                  # 充电站点：机器人在此站点进行充电（Phase 3 使用）

# 站点类型。
# 取值范围：0 (TYPE_PICKUP) | 1 (TYPE_DROPOFF) | 2 (TYPE_CHARGE)。
# 注意：同一站点在不同订单中可能扮演不同角色，此处为站点的默认/主要类型。
uint8 station_type
