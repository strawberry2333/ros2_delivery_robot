<!--
  delivery_mission.xml — 带电量前置检查的配送任务行为树
  CheckBattery 作为 Sequence 前置条件：电量不足直接返回 FAILURE，
  由 executor 的失败处理中止配送（demo 级别，不恢复电量）。

  黑板变量（由 executor 设置）：
    - order_id: 订单 ID
    - pickup_station: 取货站点 ID
    - dropoff_station: 送货站点 ID
    - stations: 站点映射表 (StationMap)
    - battery_level: 当前电量百分比 (0.0~100.0)
-->
<root BTCPP_format="4" main_tree_to_execute="DeliveryMission">

  <!-- 引用 SingleDelivery 子树 -->
  <include path="single_delivery_robust.xml" />

  <BehaviorTree ID="DeliveryMission">
    <Sequence>
      <!-- 电量前置检查：不足时 FAILURE，executor 中止配送 -->
      <CheckBattery threshold="20.0" />

      <!-- 执行配送子树 -->
      <SubTree ID="SingleDelivery"
               order_id="{order_id}"
               pickup_station="{pickup_station}"
               dropoff_station="{dropoff_station}"
               bt_state="{bt_state}"
               bt_station="{bt_station}"
               bt_progress="{bt_progress}" />
    </Sequence>
  </BehaviorTree>

</root>
